// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model AccessControl {
  id        String    @id @default(cuid())
  isEnabled Boolean   @default(true)
  password  String
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt
}

model AccessSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  progress  UserProgress[]
}

model Question {
  id          Int      @id
  chapter     String
  topic       String
  question    String   @db.Text
  optionA     String   @db.Text
  optionB     String   @db.Text
  optionC     String   @db.Text
  optionD     String   @db.Text
  optionE     String?  @db.Text
  answer      String
  answerText  String   @db.Text
  explanation String   @db.Text
  keyPoints   String   @db.Text
  imageUrl    String?  @db.Text
}

model UserProgress {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  Int
  userAnswer  String?
  isCorrect   Boolean?
  isStarred   Boolean  @default(false)
  note        String?
  answeredAt  DateTime @default(now())
  session     AccessSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@unique([sessionId, questionId])
}
