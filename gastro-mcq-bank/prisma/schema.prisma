// Prisma schema for PostgreSQL (Neon/Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// Access control - master switch
model AccessControl {
  id          String    @id @default(cuid())
  isEnabled   Boolean   @default(true)
  password    String    @default("good939ramadan")
  expiresAt   DateTime?
  updatedAt   DateTime  @updatedAt
}

// Sessions
model AccessSession {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  userAgent   String?
  ipAddress   String?
  progress    UserProgress[]
}

// Questions
model Question {
  id          Int      @id
  chapter     String
  topic       String
  question    String   @db.Text
  optionA     String   @db.Text
  optionB     String   @db.Text
  optionC     String   @db.Text
  optionD     String   @db.Text
  optionE     String?  @db.Text
  answer      String
  answerText  String   @db.Text
  explanation String   @db.Text
  keyPoints   String   @db.Text
  imageUrl    String?  @db.Text
}

// Progress
model UserProgress {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  Int
  userAnswer  String?
  isCorrect   Boolean?
  isStarred   Boolean  @default(false)
  note        String?
  answeredAt  DateTime @default(now())
  session     AccessSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@unique([sessionId, questionId])
}
